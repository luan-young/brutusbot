<?xml version="1.0"?>
<robot name="brutusbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.3" />
    <xacro:property name="base_width" value="0.25" />
    <xacro:property name="base_height" value="0.1" />
    <xacro:property name="base_mass" value="5.0" />
    <xacro:property name="motor_length" value="0.10" />
    <xacro:property name="motor_width" value="0.056" />
    <xacro:property name="motor_height" value="0.056" />
    <xacro:property name="motor_mass" value="1.0" />
    <xacro:property name="motor_position" value="${-((base_length / 2.0) - (motor_width / 2.0) - 0.005)}" />
    <xacro:property name="wheel_radius" value="0.05" />
    <xacro:property name="wheel_length" value="0.02" />
    <xacro:property name="wheel_mass" value="1.0" />
    <xacro:property name="caster_wheel_radius" value="${(wheel_radius + motor_height / 2.0) / 2.0}" />
    <xacro:property name="caster_wheel_mass" value="1.0" />
    <xacro:property name="caster_wheel_position" value="${(base_length / 2.0) - caster_wheel_radius - 0.005}" />

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
        </collision>
        <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"
            o_xyz="0 0 ${base_height / 2.0}" o_rpy="0 0 0"/>
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link" />
        <origin xyz="${-motor_position} 0 ${wheel_radius + motor_height / 2.0}" rpy="0 0 0"/>
    </joint>

    <xacro:macro name="motor_link" params="prefix">
        <link name="${prefix}_motor_link">
            <visual>
                <geometry>
                    <box size="${motor_length} ${motor_width} ${motor_height}"/>
                </geometry>
                <origin xyz="${-motor_length / 2.0} 0 0" rpy="0 0 0"/>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <box size="${motor_length} ${motor_width} ${motor_height}"/>
                </geometry>
                <origin xyz="${-motor_length / 2.0} 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:box_inertia m="${motor_mass}" x="${motor_length}" y="${motor_width}" z="${motor_height}"
                o_xyz="${-motor_length / 2.0} 0 0" o_rpy="0 0 0"/>
        </link>
    </xacro:macro>

    <xacro:motor_link prefix="left" />
    <xacro:motor_link prefix="right" />

    <joint name="base_left_motor_joint" type="fixed">
        <parent link="base_link"/>
        <child link="left_motor_link" />
        <origin xyz="${motor_position} ${base_width / 2.0} ${-motor_height / 2.0}" rpy="0 0 ${pi / 2.0}"/>
    </joint>

    <joint name="base_right_motor_joint" type="fixed">
        <parent link="base_link"/>
        <child link="right_motor_link" />
        <origin xyz="${motor_position} ${-base_width / 2.0} ${-motor_height / 2.0}" rpy="0 0 ${-pi / 2.0}"/>
    </joint>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="gray"/>
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_length}"
                o_xyz="0 0 0" o_rpy="0 0 0"/>
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="left" />
    <xacro:wheel_link prefix="right" />

    <joint name="left_motor_wheel_joint" type="continuous">
        <parent link="left_motor_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="${wheel_length / 2.0} 0 0" rpy="0 ${pi / 2.0} 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="right_motor_wheel_joint" type="continuous">
        <parent link="right_motor_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="${wheel_length / 2.0} 0 0" rpy="0 ${pi / 2.0} 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${caster_wheel_radius}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="gray"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${caster_wheel_radius}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <xacro:sphere_inertia m="${caster_wheel_mass}" r="${caster_wheel_radius}"
            o_xyz="0 0 0" o_rpy="0 0 0"/>
    </link>

    <joint name="base_caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>
        <origin xyz="${caster_wheel_position} 0 ${-caster_wheel_radius}" rpy="0 0 0"/>
    </joint>

</robot>